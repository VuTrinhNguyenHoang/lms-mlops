PROJECT_ROOT=/app
LOCAL_STORAGE_DIR=/app/storage
LOCAL_OUTPUT_DIR=/app/outputs
REFERENCE_DATA_PATH=/app/data/reference/simulated_data.csv

MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_REGISTRY_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=lms-dropout-risk
MLFLOW_REGISTERED_MODEL_NAME=lms-dropout-risk-model
