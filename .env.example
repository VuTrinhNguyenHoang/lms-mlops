MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lms-mlops
MINIO_SECURE=false

RISK_THRESHOLD=0.5
DATA_DRIFT_SHARE_THRESHOLD=0.5
PREDICTION_SCORE_DRIFT_THRESHOLD=0.05
